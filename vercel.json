{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(signup|signin|reports|reportWaste|report/:id|report/:id/status|leaderboard|seed|reports/all|analyzeWaste)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/:path*"
    }
  ]
}
